generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entity {
  id            String   @id @default(cuid())
  name          String
  type          String
  verified      Boolean  @default(false)
  logoUrl       String?
  chains        String[]
  totalUsdValue Float    @default(0)
  change1d      Float    @default(0)
  wallets       Wallet[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([totalUsdValue(sort: Desc)])
}

model Wallet {
  id           String   @id @default(cuid())
  address      String   @unique
  chain        String
  entityId     String?
  entity            Entity?           @relation(fields: [entityId], references: [id])
  smartMoneyWallet  SmartMoneyWallet?
  labels            String[]
  riskScore         Int               @default(0)
  lastSeen     DateTime
  holdings     TokenHolding[]
  transactions Transaction[]
  createdAt    DateTime @default(now())

  @@index([chain])
  @@index([entityId])
}

model Token {
  id             String   @id @default(cuid())
  address        String
  chain          String
  name           String
  symbol         String
  price          Float    @default(0)
  marketCap      Float    @default(0)
  volume24h      Float    @default(0)
  holderCount    Int      @default(0)
  smartMoneyFlow Float    @default(0)
  holdings       TokenHolding[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([address, chain])
  @@index([smartMoneyFlow(sort: Desc)])
  @@index([volume24h(sort: Desc)])
}

model TokenHolding {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tokenId  String
  token    Token  @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  amount   Float
  usdValue Float

  @@unique([walletId, tokenId])
  @@index([usdValue(sort: Desc)])
}

model Transaction {
  id            String   @id @default(cuid())
  walletId      String?
  wallet        Wallet?  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  chain         String   @default("ethereum")
  txHash        String
  from          String?
  to            String?
  blockNumber   BigInt?
  value         Float    @default(0)
  amountRaw     String?
  amountUsd     Float    @default(0)
  tokenSymbol   String?
  tokenAddress  String?
  dex           String?
  isMEV         Boolean  @default(false)
  approval      Boolean  @default(false)
  timestamp     DateTime

  @@unique([chain, txHash])
  @@index([walletId, timestamp(sort: Desc)])
  @@index([chain, timestamp(sort: Desc)])
  @@index([amountUsd(sort: Desc)])
}

model PredictionMarket {
  id          String   @id @default(cuid())
  category    String
  symbol      String
  resolvedAt  DateTime?
  outcome     String?
  volume24h   Float    @default(0)
  totalVolume Float    @default(0)
  traderCount Int      @default(0)
  status      String   @default("open")
  trades      PredictionTrade[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, status])
  @@index([volume24h(sort: Desc)])
  @@index([totalVolume(sort: Desc)])
  paperTrades  PaperTrade[]
}

model PredictionTrade {
  id        String   @id @default(cuid())
  marketId  String
  market    PredictionMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  wallet    String
  direction String
  shares    Float
  price     Float
  timestamp DateTime

  @@index([marketId, timestamp(sort: Desc)])
  @@index([wallet])
}

model Alert {
  id            String   @id @default(cuid())
  userId        String
  triggerType   String
  conditions    Json
  templateId    String?
  name          String?
  condition     String?
  webhookUrl    String?
  webhookSecret String?
  isActive      Boolean  @default(true)
  lastFired     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, isActive])
}

model SmartMoneyWallet {
  id       String   @id @default(cuid())
  walletId String   @unique
  wallet   Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category String
  score    Float
  addedAt  DateTime @default(now())

  @@index([score(sort: Desc)])
  @@index([category])
}

model DeFiProtocol {
  id               String   @id @default(cuid())
  name             String
  chain            String
  category         String
  tvl              Float    @default(0)
  tvlChange24h     Float    @default(0)
  volume24h        Float    @default(0)
  uniqueUsers      Int      @default(0)
  smartMoneyInflow Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tvl(sort: Desc)])
  @@index([chain, category])
  @@index([smartMoneyInflow(sort: Desc)])
}

model NFTCollection {
  id             String   @id @default(cuid())
  name           String
  address        String   @unique
  chain          String
  floorPrice     Float    @default(0)
  volume24h      Float    @default(0)
  uniqueHolders  Int      @default(0)
  smartMoneyPct  Float    @default(0)
  washTradeScore Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([volume24h(sort: Desc)])
  @@index([floorPrice(sort: Desc)])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         String   @default("free")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model IndexerCheckpoint {
  id         String   @id @default(cuid())
  chain      String   @unique
  lastBlock  BigInt   @default(0)
  lastTxHash String?
  updatedAt  DateTime @updatedAt
}

model CexExchange {
  id                 String   @id @default(cuid())
  name               String   @unique
  status             String   @default("unknown")
  makerFee           Float    @default(0)
  takerFee           Float    @default(0)
  spotVolumeUsd24h   Float    @default(0)
  futuresVolumeUsd24h Float   @default(0)
  serverTime         DateTime?
  lastUpdate         DateTime @default(now())

  @@index([status])
}

model CexPair {
  id                  String   @id @default(cuid())
  exchange            String
  symbol              String
  baseSymbol          String
  quoteSymbol         String
  pairType            String
  priceUsd            Float    @default(0)
  priceChange24h      Float    @default(0)
  volumeUsd24h        Float    @default(0)
  openInterestUsd     Float    @default(0)
  fundingRate         Float    @default(0)
  bidAskSpreadBps     Float    @default(0)
  isActive            Boolean  @default(true)
  updatedAt           DateTime @updatedAt

  @@unique([exchange, symbol])
  @@index([exchange])
  @@index([volumeUsd24h(sort: Desc)])
  @@index([openInterestUsd(sort: Desc)])
}

model CexFundingRate {
  id               String   @id @default(cuid())
  exchange         String
  symbol           String
  fundingRate      Float
  fundingTime      DateTime
  nextFundingTime  DateTime?
  magnitude        String
  timestamp        DateTime @default(now())

  @@index([exchange, symbol, timestamp(sort: Desc)])
  @@index([fundingTime(sort: Desc)])
}

model CexLiquidation {
  id                String   @id @default(cuid())
  exchange          String
  symbol            String
  side              String
  quantity          Float
  liquidationPrice  Float
  estimatedValueUsd Float
  isWhale           Boolean  @default(false)
  whaleTier         String?
  timestamp         DateTime

  @@index([exchange, timestamp(sort: Desc)])
  @@index([estimatedValueUsd(sort: Desc)])
  @@index([isWhale])
}

model BotSignal {
  id         String   @id @default(cuid())
  symbol     String
  direction  String
  confidence Float
  source     String
  grade      String
  entryPrice Float?
  metadata   Json?
  timestamp  DateTime @default(now())

  @@index([symbol, timestamp(sort: Desc)])
  @@index([confidence(sort: Desc)])
}

model BotTrade {
  id        String   @id @default(cuid())
  tradeId   String   @unique
  symbol    String
  action    String
  entryPrice Float
  exitPrice Float?
  stake     Float
  outcome   String
  profitUsd Float    @default(0)
  pips      Float    @default(0)
  strategy  String?
  source    String?
  openTime  DateTime
  closeTime DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([symbol])
  @@index([outcome])
  @@index([openTime(sort: Desc)])
}

model NewsArticle {
  id          String   @id @default(cuid())
  sourceId    String
  title       String
  summary     String?
  url         String   @unique
  publishedAt DateTime
  assets      String[]
  sentiment   String?
  category    String
  createdAt   DateTime @default(now())

  @@index([publishedAt])
  @@index([assets])
}

model MacroDataPoint {
  id       String   @id @default(cuid())
  seriesId String
  sourceId String
  value    Float
  date     DateTime
  metadata Json?

  @@unique([seriesId, date])
  @@index([seriesId])
}

model MarketSnapshot {
  id        String   @id @default(cuid())
  symbol    String
  sourceId  String
  price     Float
  change24h Float?
  volume24h Float?
  marketCap Float?
  timestamp DateTime @default(now())

  @@index([symbol, timestamp])
}

model ModuleConfig {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, moduleId])
}

model ModuleHealthRecord {
  id          String   @id @default(cuid())
  moduleId    String   @unique
  sourceType  String
  status      String
  lastChecked DateTime @default(now())
  lastSuccess DateTime?
  failureCount Int     @default(0)
  notes       String?
}

model UserApiKey {
  id        String   @id @default(cuid())
  userId    String
  service   String
  apiKey    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, service])
}

model EntityLabel {
  id         String   @id @default(cuid())
  address    String   @unique
  chain      String
  label      String
  category   String
  source     String?
  confidence Float?
  createdAt  DateTime @default(now())

  @@index([chain])
  @@index([category])
}

model CorrelationSnapshot {
  id        String   @id @default(cuid())
  pair      String
  r         Float
  pValue    Float
  sampleSize Int
  createdAt DateTime @default(now())

  @@index([pair, createdAt])
}

model PaperTrade {
  id            String           @id @default(cuid())
  marketId      String
  market        PredictionMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  userId        String           @default("default")
  direction     String
  shares        Float
  entryPrice    Float
  exitPrice     Float?
  resolvedPrice Float?
  outcome       String?
  status        String           @default("open")
  pnl           Float            @default(0)
  notes         String?
  closedAt      DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId, status])
  @@index([marketId])
  @@index([createdAt(sort: Desc)])
  @@index([status])
}

model DerivativesSnapshot {
  id             String   @id @default(cuid())
  exchange       String
  symbol         String
  fundingRate    Float    @default(0)
  openInterest   Float    @default(0)
  longShortRatio Float?
  markPrice      Float?
  indexPrice     Float?
  timestamp      DateTime @default(now())

  @@index([exchange, symbol, timestamp(sort: Desc)])
  @@index([fundingRate(sort: Desc)])
}

model LiquidationEvent {
  id               String   @id @default(cuid())
  exchange         String
  symbol           String
  side             String
  quantity         Float
  price            Float
  estimatedValueUsd Float
  timestamp        DateTime

  @@index([exchange, timestamp(sort: Desc)])
  @@index([estimatedValueUsd(sort: Desc)])
  @@index([symbol, timestamp(sort: Desc)])
}

model SentimentSnapshot {
  id           String   @id @default(cuid())
  source       String
  score        Float
  label        String?
  metadata     Json?
  timestamp    DateTime @default(now())

  @@index([source, timestamp(sort: Desc)])
}

model UnlockEvent {
  id               String   @id @default(cuid())
  token            String
  unlockDate       DateTime
  amountUsd        Float?
  percentOfSupply  Float?
  source           String
  createdAt        DateTime @default(now())

  @@index([unlockDate(sort: Desc)])
  @@index([token])
}

model ETFFlowSnapshot {
  id               String   @id @default(cuid())
  issuer           String
  asset            String
  netFlowUsd       Float
  cumulativeFlowUsd Float   @default(0)
  date             DateTime
  createdAt        DateTime @default(now())

  @@unique([issuer, asset, date])
  @@index([asset, date(sort: Desc)])
}

model PremiumSnapshot {
  id          String   @id @default(cuid())
  venuePair   String
  asset       String
  premiumPct  Float
  timestamp   DateTime @default(now())

  @@index([venuePair, asset, timestamp(sort: Desc)])
}

model MempoolEvent {
  id          String   @id @default(cuid())
  chain       String
  type        String
  asset       String
  estUsd      Float?
  detectedAt  DateTime
  confirmedAt DateTime?
  metadata    Json?

  @@index([chain, detectedAt(sort: Desc)])
  @@index([type, detectedAt(sort: Desc)])
}

model BridgeFlowEvent {
  id           String   @id @default(cuid())
  sourceChain  String
  destChain    String
  asset        String
  amountUsd    Float
  timestamp    DateTime

  @@index([sourceChain, destChain, timestamp(sort: Desc)])
  @@index([amountUsd(sort: Desc)])
}

model StakingFlowSnapshot {
  id          String   @id @default(cuid())
  asset       String
  entryQueue  Float?
  exitQueue   Float?
  netStaked   Float?
  timestamp   DateTime @default(now())

  @@index([asset, timestamp(sort: Desc)])
}

model CreditRiskSnapshot {
  id               String   @id @default(cuid())
  protocol         String
  asset            String
  atRiskUsd        Float
  avgHealthFactor  Float?
  positionCount    Int?
  timestamp        DateTime @default(now())

  @@index([protocol, timestamp(sort: Desc)])
  @@index([atRiskUsd(sort: Desc)])
}

model MinerFlowSnapshot {
  id                      String   @id @default(cuid())
  outflowToExchangesUsd   Float
  hashRate                Float?
  timestamp               DateTime @default(now())

  @@index([timestamp(sort: Desc)])
}

model SectorFlowSnapshot {
  id                    String   @id @default(cuid())
  sector                String
  netSmartMoneyFlowUsd  Float
  tokenCount            Int
  timestamp             DateTime @default(now())

  @@index([sector, timestamp(sort: Desc)])
  @@index([netSmartMoneyFlowUsd(sort: Desc)])
}

model DevActivitySnapshot {
  id          String   @id @default(cuid())
  package     String
  ecosystem   String
  category    String
  downloads   Int
  period      String   @default("last-month")
  timestamp   DateTime @default(now())

  @@index([package, timestamp(sort: Desc)])
  @@index([ecosystem, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
}

model AttentionSnapshot {
  id        String   @id @default(cuid())
  source    String   // github, google_trends, composite
  metric    String   // stars, forks, commits, search_index
  repo      String?  // github repo name
  value     Float
  timestamp DateTime @default(now())

  @@index([source, metric, timestamp(sort: Desc)])
}

model StablecoinSnapshot {
  id        String   @id @default(cuid())
  coin      String
  marketCap Float
  dominance Float?
  change24h Float?
  timestamp DateTime @default(now())

  @@index([coin, timestamp(sort: Desc)])
}
model CycleIndicatorSnapshot {
  id        String   @id @default(cuid())
  indicator String   // mvrv, nupl, ssr, dominance
  value     Float
  zone      String   // euphoria, bull, neutral, accumulation, capitulation
  timestamp DateTime @default(now())

  @@index([indicator, timestamp(sort: Desc)])
}
model InfraSignalSnapshot {
  id        String   @id @default(cuid())
  metric    String   // lightning_capacity, lightning_nodes, mempool_congestion, mempool_fee, hashrate, adoption_composite
  value     Float
  unit      String   // BTC, nodes, txs, sat/vB, EH/s, score
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([metric, timestamp(sort: Desc)])
}

model DerivativesIntelSnapshot {
  id        String   @id @default(cuid())
  metric    String   // max_pain, term_structure, funding_heatmap
  asset     String   // BTC, ETH
  value     Float
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([metric, asset, timestamp(sort: Desc)])
}

model BacktestResult {
  id            String   @id @default(cuid())
  symbol        String
  direction     String
  entryPrice    Float
  tp1           Float?
  tp2           Float?
  tp3           Float?
  sl            Float?
  outcome       String   // win, loss, expired
  exitPrice     Float?
  pnlPercent    Float?
  hitTarget     String?  // tp1, tp2, tp3, sl, none
  durationHours Float?
  source        String   // funding-rate, whale-alert, fear-greed, trade-flow
  signalId      String?
  backtestDate  DateTime
  createdAt     DateTime @default(now())

  @@index([symbol, backtestDate(sort: Desc)])
  @@index([outcome])
  @@index([source])
}
