# ── Local Development ─────────────────────────────────────────
DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:4400"  # Production: https://tracker.aitradepulse.com
REDIS_URL="redis://localhost:6379"
NEXT_PUBLIC_APP_URL="http://localhost:4400"
NEXT_PUBLIC_WS_URL="ws://localhost:4401"
NEXUS_API_KEYS="nexus-dev-key"

# ── Docker Compose ────────────────────────────────────────────
POSTGRES_PASSWORD=nexus

# ── Blockchain Indexer (all free, no keys needed) ─────────────
# Override RPC endpoints if needed (defaults are free public nodes)
# ETH_WS_URL=wss://ethereum-rpc.publicnode.com
# ARB_WS_URL=wss://arbitrum-one-rpc.publicnode.com
# BASE_WS_URL=wss://base-rpc.publicnode.com
# OP_WS_URL=wss://optimism-rpc.publicnode.com
# SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
LOG_LEVEL=info

# ── Alchemy (optional, free tier: 30M CU/month) ──────────────
# Sign up: https://www.alchemy.com/
# Enhanced: token balances, transfers, NFT data, smart WebSockets
#ALCHEMY_API_KEY=your-alchemy-api-key

# ── Helius (optional, free tier: 100K credits/day) ────────────
# Sign up: https://www.helius.dev/
# Enhanced Solana: enriched transactions, DAS API, webhooks
#HELIUS_API_KEY=your-helius-api-key

# ── Etherscan-compatible APIs (optional, free: 5 calls/sec) ───
# Sign up: https://etherscan.io/apis
# Transaction history, token transfers, gas prices
#ETHERSCAN_API_KEY=your-etherscan-api-key
#ARBISCAN_API_KEY=your-arbiscan-api-key
#BASESCAN_API_KEY=your-basescan-api-key
#OPTIMISM_ETHERSCAN_API_KEY=your-optimism-etherscan-api-key
#BSCSCAN_API_KEY=your-bscscan-api-key
#POLYGONSCAN_API_KEY=your-polygonscan-api-key

# ── Data Sources (always free, no keys needed) ────────────────
# DeFiLlama — TVL, yields, DEX volumes, stablecoins, bridges
# Jupiter   — Solana token pricing
# CoinGecko — Market data (free tier)
# DexScreener — DEX pair data (free)
# Blockstream — Bitcoin blockchain data (free)
# Polymarket  — Prediction market data (free)
# Reservoir   — NFT data (free)

# ── More Free Data Sources ──────────────────────────────────
# CryptoCompare (free tier, optional key for higher limits)
#CRYPTOCOMPARE_API_KEY=your-cryptocompare-api-key

# LunarCrush (free tier available)
# Sign up: https://lunarcrush.com/developers
# Social sentiment, Galaxy Score, Alt Rank
#LUNARCRUSH_API_KEY=your-lunarcrush-api-key

# ── Always Free (no keys needed) ────────────────────────────
# GeckoTerminal — DEX trending pools, new pairs, OHLCV (260+ networks)
# CoinPaprika   — 50K+ assets, tickers, global market overview
# CoinGecko     — Market data, prices
# DexScreener   — DEX pair data
# Jupiter       — Solana token pricing
# DeFiLlama     — TVL, yields, DEX volumes, stablecoins
# Polymarket    — Prediction market data
# Blockstream   — Bitcoin blockchain data
# Reservoir     — NFT data
