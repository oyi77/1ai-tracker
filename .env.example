# ── NEXUS Terminal — Zero-Config Environment ──────────────────
# All data modules work out of the box with zero API keys.
# The only optional key is ANTHROPIC_API_KEY (user-supplied via Settings UI).

# ── Infrastructure (Docker Compose sets these automatically) ──
DATABASE_URL="postgresql://nexus:nexus@localhost:5432/nexus"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:4400"
REDIS_URL="redis://localhost:6379"
NEXT_PUBLIC_APP_URL="http://localhost:4400"
NEXT_PUBLIC_WS_URL="ws://localhost:4401"
NEXUS_API_KEYS="nexus-dev-key"
POSTGRES_PASSWORD=nexus
LOG_LEVEL=info

# ── Telegram Bot (optional — for alert delivery) ──────────
# TELEGRAM_BOT_TOKEN="your-bot-token-from-@BotFather"

# ── RPC Overrides (optional — defaults are free public nodes) ─
# ETH_WS_URL=wss://ethereum-rpc.publicnode.com
# ARB_WS_URL=wss://arbitrum-one-rpc.publicnode.com
# BASE_WS_URL=wss://base-rpc.publicnode.com
# OP_WS_URL=wss://optimism-rpc.publicnode.com
# SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# ── AI Assistant (optional — user supplies via Settings UI) ───
# ANTHROPIC_API_KEY is stored encrypted per-user in the database,
# NOT read from this file. Users enter it at /settings/modules.

# ── FRED API (optional — unlocks all 22 macro series) ─────
# Get your free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Without this key: 21/22 series still work (Treasury CSV + World Bank)
# FRED_API_KEY=your-32-char-lowercase-key-here

# ── Stripe Payments (optional — for subscription billing) ─────
# Get your keys: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
